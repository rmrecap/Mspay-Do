# Firebase Configuration
FIREBASE_DATABASE_URL=https://mspay-do-default-rtdb.firebaseio.com

# Service Account Credentials (pick ONE method):
# Option A: Render-friendly - paste entire JSON into one env variable
FIREBASE_KEY_JSON={"type":"service_account","project_id":"mspay-do",...}
# Option B: Local file path
# FIREBASE_CREDENTIALS_PATH=firebase-key.json

# JWT Secret - change to a strong random key in production
JWT_SECRET_KEY=jaihind

# Optional: Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=*

# Optional: Deta fallback (not needed with Firebase)
# DETA_PROJECT_KEY=your_deta_project_key
